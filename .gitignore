# === Composer-managed code (regenerated by `composer install`) ===
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/*
# Front-end libraries committed to the repo (the Drupal modules require them and
# they have no Composer package wired up): Chosen and Select2.
!/web/libraries/chosen
!/web/libraries/select2
/drush/Commands/contrib/

# === Site files & local/secret settings ===
/web/sites/*/files/
/web/sites/*/private/
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/*/translations/
/web/sites/simpletest/

# === Large data / dumps (never commit DB dumps — GitHub rejects >100MB) ===
*.sql
*.sql.gz
*.sql.zip
/web/all.csv

# === Logs & scratch ===
*.log
error_log
php_errorlog
*.bak
composer.old

# === Editor / OS ===
.idea/
.vscode/
.DS_Store
