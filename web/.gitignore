# Ignore paths that may contain user-generated content
/sites/*/files
/sites/*/public
/sites/*/private
/sites/*/files-public
/sites/*/files-private

# Ignore paths that may contain temporary files
/sites/*/translations
/sites/*/tmp
/sites/*/cache

# Ignore testing related files
/sites/simpletest

# Ignore drupal core (if not versioning drupal sources)
/core
/vendor
/modules/contrib

/drush/Commands/contrib/
/web/core/
/web/modules/composer/
/web/themes/composer/
/web/profiles/composer/
/web/libraries/
/web/private/scripts/quicksilver

.idea/

/README.md