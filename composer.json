{
  "name": "drupal/project",
  "description": "Provider Guide - Drupal 11 project",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "homepage": "https://www.drupal.org/project/drupal",
  "repositories": [
    {
      "type": "composer",
      "url": "https://packages.drupal.org/8"
    }
  ],
  "require": {
    "composer/installers": "^2.2",
    "drupal/admin_toolbar": "^3.4",
    "drupal/adsense": "^1.3",
    "drupal/block_visibility_conditions": "^1.0",
    "drupal/chosen": "^4.0",
    "drupal/core-composer-scaffold": "^11.0",
    "drupal/core-project-message": "^11.0",
    "drupal/core-recommended": "^11.0",
    "drupal/core-vendor-hardening": "^11.0",
    "drupal/devel_kint_extras": "^1.1",
    "drupal/electra": "^3.2",
    "drupal/field_group": "^3.4",
    "drupal/gin": "^4.0",
    "drupal/google_tag": "^2.0",
    "drupal/gtm": "^1.7",
    "drupal/metatag": "^2.0",
    "drupal/migrate_plus": "^6.0",
    "drupal/migrate_source_csv": "^3.5",
    "drupal/migrate_tools": "^6.0",
    "drupal/pathauto": "^1.13",
    "drupal/scheduler": "^2.3",
    "drupal/schema_metatag": "^3.0",
    "drupal/seckit": "^2.0",
    "drupal/select2": "^1.13",
    "drupal/simple_sitemap": "^4.0",
    "drupal/smtp": "^1.2",
    "drupal/taxonomy_delete": "^1.2",
    "drupal/title_field_for_manage_display": "^2.1",
    "drupal/twig_field_value": "^2.0",
    "drupal/twig_tweak": "^3.4",
    "drupal/views_data_export": "^1.4",
    "drupal/webform": "^6.3",
    "drupal/webp": "^1.0",
    "drupal/yoast_seo": "^2.0",
    "drush/drush": "^13.0",
    "mglaman/composer-drupal-lenient": "^1.0"
  },
  "conflict": {
    "drupal/drupal": "*"
  },
  "scripts": {
    "d11-compat": "@php scripts/d11-compat.php",
    "post-install-cmd": ["@d11-compat"],
    "post-update-cmd": ["@d11-compat"]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "composer/installers": true,
      "drupal/core-composer-scaffold": true,
      "drupal/core-project-message": true,
      "drupal/core-vendor-hardening": true,
      "mglaman/composer-drupal-lenient": true
    }
  },
  "extra": {
    "drupal-scaffold": {
      "locations": {
        "web-root": "./web"
      },
      "file-mapping": {
        "[web-root]/.htaccess": false
      }
    },
    "installer-paths": {
      "web/core": ["type:drupal-core"],
      "web/libraries/{$name}": ["type:drupal-library"],
      "web/modules/contrib/{$name}": ["type:drupal-module"],
      "web/profiles/contrib/{$name}": ["type:drupal-profile"],
      "web/themes/contrib/{$name}": ["type:drupal-theme"],
      "drush/Commands/contrib/{$name}": ["type:drupal-drush"],
      "web/modules/custom/{$name}": ["type:drupal-custom-module"],
      "web/profiles/custom/{$name}": ["type:drupal-custom-profile"],
      "web/themes/custom/{$name}": ["type:drupal-custom-theme"]
    },
    "drupal-lenient": {
      "allowed-list": ["drupal/admin_toolbar", "drupal/adsense", "drupal/block_visibility_conditions", "drupal/chosen", "drupal/devel_kint_extras", "drupal/electra", "drupal/field_group", "drupal/google_tag", "drupal/gtm", "drupal/metatag", "drupal/migrate_plus", "drupal/migrate_source_csv", "drupal/migrate_tools", "drupal/pathauto", "drupal/schema_metatag", "drupal/seckit", "drupal/select2", "drupal/simple_sitemap", "drupal/smtp", "drupal/taxonomy_delete", "drupal/title_field_for_manage_display", "drupal/twig_field_value", "drupal/twig_tweak", "drupal/views_data_export", "drupal/webform", "drupal/webp", "drupal/yoast_seo"]
    }
  }
}
